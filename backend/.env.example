EODHD_API_KEY=your_eodhd_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FRED_API_KEY=your_fred_key_here

# Trading symbol (EODHD format)
# NQ futures continuous: NQ.INDX or use QQQ.US as proxy
DEFAULT_SYMBOL=NQ.INDX
DEFAULT_EXCHANGE=INDX

# Backtest defaults
DEFAULT_ACCOUNT_SIZE=100000
DEFAULT_RISK_PER_TRADE=0.0025

# Cache directory
CACHE_DIR=./cache
